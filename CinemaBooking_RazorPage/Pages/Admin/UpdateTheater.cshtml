@page
@model CinemaBooking_RazorPage.Pages.Admin.UpdateTheaterModel
@{
}

<!DOCTYPE html>

<html class="dark" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@100;300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#ff8c00",
                        "background-light": "#f8f7f5",
                        "background-dark": "#231a0f",
                        "input-dark": "#2a2a2a",
                    },
                    fontFamily: {
                        "display": ["Be Vietnam Pro", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        :root {
            --primary-color: #ff8c00;
        }

        .bg-primary-important {
            background-color: var(--primary-color) !important;
        }

        .text-primary-important {
            color: var(--primary-color) !important;
        }

        .border-primary-important {
            border-color: var(--primary-color) !important;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: #1e1e1e;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 10px;
        }

            .custom-scrollbar::-webkit-scrollbar-thumb:hover {
                background: var(--primary-color);
            }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-x-hidden">
    <div class="flex min-h-screen">
        <!-- Side Navigation Bar -->
        <aside class="fixed left-0 top-0 h-screen w-72 bg-slate-900/50 dark:bg-black/40 backdrop-blur-xl border-r border-slate-200 dark:border-slate-800 z-50">
            <div class="flex flex-col h-full p-6">
                <!-- Logo -->
                <div class="flex items-center gap-3 mb-10 px-2">
                    <div class="w-10 h-10 rounded-full bg-primary-important flex items-center justify-center shadow-lg shadow-orange-500/20">
                        <span class="material-symbols-outlined text-black font-bold">movie</span>
                    </div>
                    <div>
                        <h1 class="text-xl font-black tracking-tight text-white">Cinema<span class="text-primary-important">VN</span></h1>
                        <p class="text-[10px] uppercase tracking-widest text-slate-400 font-bold">Admin Panel</p>
                    </div>
                </div>
                <!-- Navigation -->
                <nav class="flex-1 space-y-2">
                    <a class="flex items-center gap-3 px-4 py-3 rounded-full text-slate-400 hover:bg-slate-800 hover:text-white transition-all" href="ManageMovie">
                        <span class="material-symbols-outlined">movie_filter</span>
                        <span>Quản lý phim</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-full bg-primary-important text-black font-bold transition-all" href="ManageTheater">
                        <span class="material-symbols-outlined">domain</span>
                        <span>Quản lý rạp phim</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-full text-slate-400 hover:bg-slate-800 hover:text-white transition-all" href="ManageRoom">
                        <span class="material-symbols-outlined">meeting_room</span>
                        <span>Quản lý phòng chiếu</span>
                    </a>
                    <a class="flex items-center gap-3 px-4 py-3 rounded-full text-slate-400 hover:bg-slate-800 hover:text-white transition-all" href="ManageShowtime">
                        <span class="material-symbols-outlined">schedule</span>
                        <span>Quản lý suất chiếu</span>
                    </a>
                </nav>
                <!-- Bottom Actions -->
                <div class="mt-auto space-y-2 pt-6 border-t border-slate-800">
                    <form method="post" asp-page-handler="Logout">
                        <button type="submit" class="flex items-center gap-3 px-4 py-3 rounded-full text-red-400 hover:bg-red-500/10 transition-all">
                            <span class="material-symbols-outlined">logout</span>
                            <span>Đăng xuất</span>
                        </button>
                    </form>
                </div>
            </div>
        </aside>
        <!-- Main Content Area -->
        <main class="flex-1 ml-72 min-h-screen flex flex-col">
            <!-- Header -->
            <header class="flex items-center justify-between px-8 py-6 sticky top-0 bg-background-dark/80 backdrop-blur-md z-40 border-b border-primary/10">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined primary-important text-3xl">edit_square</span>
                    <div>
                        <h2 class="text-2xl font-bold text-slate-100">Cập nhật rạp</h2>
                        <p class="text-slate-400 text-sm">Chỉnh sửa thông tin rạp chiếu phim trong hệ thống</p>
                    </div>
                </div>
            </header>
            <!-- Update Form Section -->
            <div class="p-8 max-w-5xl mx-auto w-full flex-grow">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="bg-green-500 text-white p-3 rounded-lg mb-4">
                        @TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="bg-red-500 text-white p-3 rounded-lg mb-4">
                        @TempData["ErrorMessage"]
                    </div>
                }
                <form method="post" class="space-y-8 pb-20">
                    <input type="hidden" asp-for="TheaterId" />
                    <div class="grid-cols-1 md:grid-cols-12 gap-8 items-start">
                        <div class="space-y-6">
                            <div class="bg-input-dark/40 p-6 rounded-2xl border border-white/5 space-y-6">
                                <!-- Theater Name -->
                                <div class="flex flex-col gap-2">
                                    <label class="text-slate-300 text-sm font-bold">
                                        Tên rạp <span class="text-primary-important">*</span>
                                    </label>
                                    <input asp-for="Input.Name"
                                           required
                                           class="w-full bg-input-dark border-primary-important text-slate-100 rounded-xl px-4 py-3 focus:ring-primary focus:border-primary placeholder-slate-500" />
                                </div>
                                <!-- City -->
                                <div class="flex flex-col gap-2">
                                    <label class="text-slate-300 text-sm font-bold">
                                        Thành phố
                                    </label>
                                    <select asp-for="Input.CityId"
                                            class="w-full bg-input-dark border-primary-important text-slate-100 rounded-xl px-4 py-3 focus:ring-primary focus:border-primary appearance-none">
                                        <option value="">-- Chọn thành phố --</option>
                                        @foreach (var city in Model.Cities)
                                        {
                                            <option value="@city.Id">@city.Name</option>
                                        }
                                    </select>
                                </div>
                                <!-- Address -->
                                <div class="flex flex-col gap-2">
                                    <label class="text-slate-300 text-sm font-bold">
                                        Địa chỉ chi tiết
                                    </label>
                                <textarea asp-for="Input.Address"
                                              rows="4"
                                              class="w-full bg-input-dark border-primary-important text-slate-100 rounded-xl px-4 py-3 focus:ring-primary focus:border-primary placeholder-slate-500 resize-none"></textarea>
                                </div>
                            </div>
                            <!-- Buttons -->
                            <div class="flex items-center justify-end gap-4 pt-4">
                                <button asp-page-handler="Cancel"
                                        type="submit"
                                        formnovalidate
                                        class="px-8 py-3 rounded-xl border border-slate-700 text-slate-400 font-bold hover:bg-slate-800 transition-all flex items-center gap-2">
                                    Trở về
                                </button>
                                <button type="submit"
                                        class="bg-primary-important text-background-dark px-10 py-3 rounded-xl font-black text-lg shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all flex items-center gap-2">

                                    <span class="material-symbols-outlined">save</span>
                                    Cập nhật rạp
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <!-- Global Footer Placeholder (Razor Page context) -->
            <footer class="mt-auto px-8 py-6 border-t border-primary/10 text-center text-slate-500 text-xs">
                Thiết kế bởi LocCute.
            </footer>
        </main>
    </div>
</body>
</html>